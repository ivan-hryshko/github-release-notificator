{
  "permissions": {
    "allow": [
      "Bash(docker-compose -f docker-compose.dev.yml up -d)",
      "Bash(docker exec:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(curl -s http://localhost:3000/health)",
      "Bash(curl -s -X POST http://localhost:3000/api/subscribe -H \"Content-Type: application/json\" -d '{\"email\":\"test@example.com\",\"repo\":\"invalid\"}')",
      "Bash(curl -s -X POST http://localhost:3000/api/subscribe -H \"Content-Type: application/json\" -d '{\"email\":\"test@example.com\",\"repo\":\"nonexistent-user-xyz/nonexistent-repo-xyz\"}')",
      "Bash(curl -s -X POST http://localhost:3000/api/subscribe -H \"Content-Type: application/json\" -d '{\"email\":\"test@example.com\",\"repo\":\"golang/go\"}')",
      "Bash(curl -s \"http://localhost:3000/api/subscriptions?email=test@example.com\")",
      "Bash(curl -s \"http://localhost:3000/api/confirm/not-a-uuid\")",
      "Bash(curl -s http://localhost:3000/api/swagger.yaml)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3000/api/docs/)",
      "Bash(npx vitest:*)"
    ]
  }
}
