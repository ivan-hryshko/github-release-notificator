# Server
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# Auth (optional — leave empty to disable)
API_KEY=

# Database
# Docker:    postgresql://app:secret@postgres:5432/releases
# Local dev: postgresql://app:secret@localhost:5432/releases
DATABASE_URL=postgresql://app:secret@localhost:5432/releases

# Redis
# Docker: redis://redis:6379
REDIS_URL=redis://localhost:6379

# GitHub (optional but recommended — 5000 req/hr vs 60)
GITHUB_TOKEN=

# SMTP — MailHog for local dev (no auth needed, UI at http://localhost:8025)
# For production: switch to Mailtrap or any real SMTP provider
# Docker: mailhog | Local dev: localhost
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=any
SMTP_PASS=any
EMAIL_FROM=noreply@releases-api.app

# GitHub cache TTL in seconds (default 600 = 10 min)
GITHUB_CACHE_TTL=600

# Scanner
SCAN_INTERVAL=*/5 * * * *
NOTIFY_INTERVAL=*/1 * * * *
NOTIFY_MAX_ATTEMPTS=3
